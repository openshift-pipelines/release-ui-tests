# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it's in .gitignore

# OpenShift Console URL
CONSOLE_URL=https://console-openshift-console.apps.example.com

# Console Login Credentials
CONSOLE_USERNAME=kubeadmin
CONSOLE_PASSWORD=your-password-here

# OpenShift CLI Token (optional - for oc commands)
# Get token from: oc whoami -t
OC_TOKEN=sha256~your-token-here

# Default timeout for UI operations (milliseconds)
APP_TIMEOUT=90000
