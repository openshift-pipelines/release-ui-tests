# ========================================
# OpenShift UI Test Framework Configuration
# ========================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values below
# 3. Never commit .env file to git (it's in .gitignore)
#
# CONFIGURATION PRIORITY (12-Factor App):
# 1. Environment Variables (set by CI/CD or export in shell) - HIGHEST PRIORITY
# 2. .env file (for local development) - FALLBACK
# 3. Defaults (hardcoded in Config class) - LAST RESORT
#
# This approach works for both:
# - Local Development: Use .env file (git-ignored, developer-specific)
# - CI/CD: Set environment variables (override .env values)
#
# ========================================

# ========================================
# REQUIRED: Console UI Configuration
# ========================================

# OpenShift Console URL (REQUIRED for all tests)
# Example: https://console-openshift-console.apps.example.com
CONSOLE_URL=https://console-openshift-console.apps.example.com

# Console Login Credentials (REQUIRED for UI and CLI tests)
# Used for both browser login and CLI fallback authentication
CONSOLE_USERNAME=kubeadmin
CONSOLE_PASSWORD=your-password-here

# ========================================
# OPTIONAL: Timeout Configuration
# ========================================

# Application timeout for element waits and page operations
# Value in milliseconds (default: 90000ms = 90 seconds)
APP_TIMEOUT=90000

# ========================================
# OPTIONAL: OpenShift CLI Token Authentication
# ========================================
#
# CLI AUTHENTICATION PRIORITY:
# 1. If OC_TOKEN + OC_API_URL are set → Use token authentication
# 2. If not set → Try existing `oc login` session
# 3. If no session → Fallback to username/password login (CONSOLE_USERNAME/CONSOLE_PASSWORD)
#
# Token authentication is recommended for CI/CD pipelines.
# For local development, you can use `oc login` instead.
#
# To get your token:
# 1. Login to OpenShift Console
# 2. Click your name (top-right) → Copy login command
# 3. Copy the token from: oc login --token=sha256~... --server=https://...
#
# Uncomment and fill these if you want token-based authentication:

# OC_TOKEN=sha256~your-token-here
# OC_API_URL=https://api.example.com:6443
