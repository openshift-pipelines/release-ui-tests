# ========================================
# OpenShift UI Test Framework Configuration
# ========================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values below
# 3. Never commit .env file to git (it's in .gitignore)


CONSOLE_URL=https://console-openshift-console.apps.example.com
CONSOLE_USERNAME=kubeadmin
CONSOLE_PASSWORD=your-password-here

# Application timeout for element waits and page operations
APP_TIMEOUT=90000
